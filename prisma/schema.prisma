generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id          String   @id
  name        String?
  email       String?
  serviceType String?
  eventDate   String?
  location    String?
  message     String?
  status      String   @default("Pending")
  createdAt   String?

  @@map("bookings")
}

model SiteConfig {
  id     Int    @id @default(1)
  config String

  @@map("site_config")
}

model Image {
  id    Int    @id @default(autoincrement())
  url   String
  title String

  @@map("images")
}
