generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id          String   @id
  name        String?
  email       String?
  serviceType String?
  eventDate   String?
  location    String?
  message     String?
  status      String   @default("Pending")
  createdAt   String?
}

model SiteConfig {
  id     Int    @id @default(1)
  config String
}

model Image {
  id    Int    @id @default(autoincrement())
  url   String
  title String
}
