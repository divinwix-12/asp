generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Booking {
  id          String   @id @default(uuid())
  clientName  String
  email       String
  serviceType String
  eventDate   DateTime
  location    String
  message     String?
  status      String   @default("PENDING")
  priority    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(uuid())
  url       String
  section   String
  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteConfig {
  id     Int    @id @default(1)
  config String
}
